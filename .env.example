PORT=3000
LOG_LEVEL=info
DATA_DIR=data
API_SECRET=replace-with-long-random-token
DEMO_PUBLIC=false
ENABLED_STRATEGIES=dex-arbitrage
ENGINE_INTERVAL_MS=5000
QUOTE_STALE_MS=1000
WS_ENABLED=false
WS_URL=
WS_RECONNECT_MS=2000
PAIR=ETH/USDC
DEX_A=okx-dex-a
DEX_B=okx-dex-b
START_MODE=paper
# SECURITY RISK: true means engine can run in live mode with real execution.
LIVE_ENABLED=false
# SECURITY RISK: true allows automatic promotion from paper to live when gate passes.
AUTO_PROMOTE_TO_LIVE=false
PAPER_START_BALANCE_USD=10000
LIVE_BALANCE_USD=3000
MIN_NET_EDGE_BPS_PAPER=45
MIN_NET_EDGE_BPS_LIVE=60
MAX_TRADE_PCT_BALANCE=0.03
MAX_DAILY_LOSS_PCT=0.015
MAX_CONSECUTIVE_FAILURES=3
SLIPPAGE_BPS=12
TAKER_FEE_BPS=20
GAS_USD_DEFAULT=1.25
MEV_PENALTY_BPS=5
LIQUIDITY_USD_DEFAULT=250000
VOLATILITY_DEFAULT=0.02
AVG_LATENCY_MS_DEFAULT=250
EVAL_NOTIONAL_USD_DEFAULT=1000
DISCOVERY_DEFAULT_DURATION_MINUTES=30
DISCOVERY_DEFAULT_SAMPLE_INTERVAL_SEC=5
DISCOVERY_DEFAULT_TOPN=20
DISCOVERY_LOOKBACK_SAMPLES=60
DISCOVERY_Z_ENTER=2
DISCOVERY_VOL_RATIO_MIN=1.8
DISCOVERY_MIN_SPREAD_BPS=35
DISCOVERY_NOTIONAL_USD=1000

# ============================================
# Network Profile — 选择你的启动路径
# ============================================
# 二选一：
#   - xlayer-recommended: X Layer 推荐路径（默认），自动配置 chain 196 + 推荐 RPC + poll 模式 + hmac auth
#   - evm-custom: 自定义 EVM 链，需要手动指定 ONCHAINOS_CHAIN_INDEX 和 COMM_RPC_URL
NETWORK_PROFILE=xlayer-recommended

# --- X Layer Recommended 路径 ---
# 当 NETWORK_PROFILE=xlayer-recommended 时，以下配置会自动使用默认值：
#   ONCHAINOS_CHAIN_INDEX=196
#   COMM_CHAIN_ID=196
#   COMM_RPC_URL=https://rpc.xlayer.tech (备用：https://xlayerrpc.okx.com)
#   COMM_LISTENER_MODE=poll
#   ONCHAINOS_AUTH_MODE=hmac
# 你只需要填写执行后端凭证（仍使用 ONCHAINOS_* 变量名）即可启动推荐路径。

# --- EVM Custom 路径 ---
# 当 NETWORK_PROFILE=evm-custom 时，必须显式指定：
# ONCHAINOS_CHAIN_INDEX=<你的链 index>
# COMM_CHAIN_ID=<你的链 ID>
# COMM_RPC_URL=<你的 RPC URL>
# COMM_LISTENER_MODE=poll

# ============================================
# 执行后端凭证（两条路径都需要，变量名保持 ONCHAINOS_* 兼容）
# ============================================
ONCHAINOS_API_BASE=
ONCHAINOS_API_KEY=
ONCHAINOS_API_SECRET=
ONCHAINOS_PASSPHRASE=
ONCHAINOS_PROJECT_ID=
ONCHAINOS_USER_WALLET_ADDRESS=
# auth mode 会被 profile 默认覆盖（xlayer-recommended 用 hmac），但可手动覆盖
ONCHAINOS_AUTH_MODE=bearer
ONCHAINOS_API_KEY_HEADER=X-API-Key
# chain index 会被 profile 默认覆盖（xlayer-recommended 用 196），但可手动覆盖
ONCHAINOS_CHAIN_INDEX=196
ONCHAINOS_REQUIRE_SIMULATE=true
# Production default: keep legacy endpoint fallback disabled unless migrating a known backend.
ONCHAINOS_ENABLE_COMPAT_FALLBACK=false
# Production risk: serial dual-leg fallback can create partial fills. Keep disabled unless explicitly accepted.
ONCHAINOS_ALLOW_SERIAL_DUAL_LEG=false
ONCHAINOS_TOKEN_CACHE_TTL_SECONDS=600
ONCHAINOS_TOKEN_PROFILE_PATH=/api/v6/market/token/profile/current

# ============================================
# Agent-Comm v0.1 (single-chain, poll-only)
# ============================================
# 当 NETWORK_PROFILE=xlayer-recommended 时，COMM_CHAIN_ID 和 COMM_LISTENER_MODE 会被自动设置
COMM_ENABLED=false
COMM_CHAIN_ID=196
COMM_RPC_URL=
# supported values: disabled | poll
COMM_LISTENER_MODE=disabled
COMM_POLL_INTERVAL_MS=5000
COMM_WALLET_ALIAS=agent-comm
COMM_RELAY_URL=
COMM_RELAY_TIMEOUT_MS=10000
# supported values: direct | relay
COMM_SUBMIT_MODE=direct
# when COMM_ENABLED=true, VAULT_MASTER_PASSWORD must be provided at startup
# optional placeholders (not in v0.1 acceptance scope)
COMM_PAYMASTER_URL=
# supported values: disabled | observe | enforce
X402_MODE=disabled

# ============================================
# Vault & Hooks
# ============================================
# VAULT_MASTER_PASSWORD 在启用 agent-comm 时必须提供
# optional values for scripts/execution-live-smoke.sh
ALPHAOS_PROBE_PAIR=ETH/USDC
ALPHAOS_PROBE_CHAIN_INDEX=196
ALPHAOS_PROBE_NOTIONAL_USD=25
ALPHAOS_PROBE_WALLET=
OPENCLAW_HOOK_URL=http://127.0.0.1:18789/hooks/wake
OPENCLAW_HOOK_TOKEN=
STRATEGY_PROFILE_DEFAULTS={"dex-arbitrage":{"variant":"A","notionalMultiplier":1}}

# ============================================
# Living Assistant Delivery (Demo)
# ============================================
# Call rehearsal without credentials:
#   npm run demo:living-assistant -- --call --demo-delivery

# Call route policy (--call)
# profile: balanced (default) | telegram-escalation | direct-call-only
CALL_ROUTE_PROFILE=balanced
# Optional per-attention route overrides (comma-separated actions):
# supported actions: telegram_text, telegram_voice, twilio_call, aliyun_call
# CALL_ROUTE_TEXT_NUDGE=telegram_text
# CALL_ROUTE_VOICE_BRIEF=telegram_voice
# CALL_ROUTE_STRONG_INTERRUPT=telegram_voice,twilio_call,aliyun_call
# CALL_ROUTE_CALL_ESCALATION=twilio_call,aliyun_call,telegram_voice

# Telegram (required for --send, optional for --call reminder/voice nudge path)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# TTS (required for --send, optional for --call)
# provider: openai-compatible (default) | dashscope-qwen | cosyvoice
TTS_PROVIDER=openai-compatible
# openai-compatible requires TTS_BASE_URL + TTS_API_KEY
TTS_BASE_URL=
TTS_API_KEY=
# shared optional overrides
TTS_MODEL=
TTS_VOICE=
TTS_LANGUAGE=
TTS_FORMAT=
# optional instructions (supported by instruct-capable models such as qwen3-tts-instruct-flash)
TTS_INSTRUCTIONS=
TTS_OPTIMIZE_INSTRUCTIONS=
# dashscope-qwen optional overrides
TTS_DASHSCOPE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
TTS_DASHSCOPE_LANGUAGE_TYPE=Auto
# cosyvoice optional overrides
# - uses same TTS_DASHSCOPE_ENDPOINT + TTS_API_KEY
# - set TTS_VOICE to a preset voice name, or an http(s) URL for voice cloning reference_audio

# Optional live polling for Binance Square narratives in --live demo mode
# Example endpoint should return a JSON array under one of: data.posts / data.list / data.items
BINANCE_SQUARE_ENDPOINT=
BINANCE_SQUARE_PAGE_SIZE=20
# optional comma-separated keyword filter, e.g. "bnb,listing,meme"
BINANCE_SQUARE_KEYWORDS=

# Aliyun voice call (phone call path for --call, template code required)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_CALLED_SHOW_NUMBER=
ALIYUN_CALLED_NUMBER=
ALIYUN_TTS_CODE=
ALIYUN_ENDPOINT=

# LLM Signal Triage (DashScope Qwen)
LLM_API_KEY=                    # DashScope API key (defaults to TTS_API_KEY if not set)
LLM_MODEL=qwen-plus             # default: qwen-plus
LLM_ENABLED=true                # set false to force rule engine fallback
